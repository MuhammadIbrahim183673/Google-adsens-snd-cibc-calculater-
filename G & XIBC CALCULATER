import React, { useState } from 'react';
import Head from 'next/head';

export default function Calculator() {
  const [pageviews, setPageviews] = useState(1000);
  const [ctr, setCTR] = useState(2.5);
  const [cpc, setCPC] = useState(0.25);
  const [xibcRate] = useState(0.0004); // example earning per second
  const [timeSpent, setTimeSpent] = useState(3600); // in seconds

  const estimatedClicks = (pageviews * ctr) / 100;
  const adsenseEarnings = estimatedClicks * cpc;
  const xibcDaily = timeSpent * xibcRate;
  const xibcMonthly = xibcDaily * 30;
  const totalDaily = adsenseEarnings + xibcDaily;

  return (
    <>
      <Head>
        <title>AdSense + XiBC Calculator</title>
        <meta name="description" content="Estimate your AdSense and XiBC earnings" />
      </Head>
      <main className="max-w-2xl mx-auto p-4">
        <h1 className="text-2xl font-bold mb-4">📊 AdSense + XiBC Earnings Calculator</h1>
        <div className="grid gap-4">
          <div>
            <label>📄 Daily Pageviews:</label>
            <input type="number" value={pageviews} onChange={e => setPageviews(Number(e.target.value))} className="w-full border p-2 rounded" />
          </div>
          <div>
            <label>🎯 CTR (%):</label>
            <input type="number" value={ctr} onChange={e => setCTR(Number(e.target.value))} className="w-full border p-2 rounded" />
          </div>
          <div>
            <label>💵 Avg. CPC ($):</label>
            <input type="number" value={cpc} onChange={e => setCPC(Number(e.target.value))} className="w-full border p-2 rounded" />
          </div>
          <div>
            <label>⏱ Time on Site (seconds/day):</label>
            <input type="number" value={timeSpent} onChange={e => setTimeSpent(Number(e.target.value))} className="w-full border p-2 rounded" />
          </div>
          <div className="mt-6 p-4 bg-white shadow rounded">
            <h2 className="font-semibold text-lg mb-2">📈 Results</h2>
            <p>Google AdSense Daily Earnings: <strong>${adsenseEarnings.toFixed(2)}</strong></p>
            <p>XiBC Daily Earnings: <strong>${xibcDaily.toFixed(4)}</strong></p>
            <p>💰 Total Daily Earnings: <strong>${totalDaily.toFixed(2)}</strong></p>
            <p>📅 XiBC Monthly Earnings: <strong>${xibcMonthly.toFixed(2)}</strong></p>
          </div>
        </div>
      </main>
    </>
  );
}// File: pages/calculator.jsx
